{
  "name": "taxilibre-backend",
  "version": "1.0.0",
  "description": "Backend API for TaxiLibre ride-hailing platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "migrate": "node src/scripts/migrate.js",
    "seed": "node src/scripts/seed.js",
    "build": "echo 'No build step required for Node.js'",
    "docker:build": "docker build -t taxilibre-backend .",
    "docker:run": "docker run -p 3003:3003 taxilibre-backend"
  },
  "keywords": [
    "taxi",
    "ride-hailing",
    "uber",
    "bolt",
    "nodejs",
    "express",
    "postgresql",
    "socket.io"
  ],
  "author": "TaxiLibre Team",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.6",
    "@socket.io/redis-adapter": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.3.0",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "permessage-deflate": "^0.1.7",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "socket.io-auth": "^1.0.0",
    "socket.io-client": "^4.8.3",
    "redis": "^4.6.13",
    "speakeasy": "^2.0.0",
    "stripe": "^14.9.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^4.19.0",
    "winston": "^3.19.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/socket.io": "^3.0.1",
    "@types/socket.io-client": "^1.4.36",
    "cross-env": "^10.1.0",
    "eslint": "^8.54.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^30.4.2",
    "latest": "^0.2.0",
    "nodemon": "^3.0.2",
    "pg": "^8.22.0",
    "sqlite3": "^6.0.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shopdstok/taxilibre.git"
  },
  "bugs": {
    "url": "https://github.com/shopdstok/taxilibre/issues"
  },
  "homepage": "https://taxilibre.vercel.app",
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "eslintConfig": {
    "extends": "standard",
    "plugins": [
      "import"
    ],
    "rules": {
      "no-console": "off",
      "no-unused-vars": "off"
    },
    "env": {
      "node": true,
      "jest": true
    }
  },
  "type": "commonjs"
}